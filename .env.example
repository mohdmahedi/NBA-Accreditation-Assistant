# ─────────────────────────────────────────────────────────────
#  NBA Accreditation Assistant – Environment Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# IBM Cloud API Key (create at cloud.ibm.com → Manage → Access → API keys)
IBM_CLOUD_API_KEY=USE YOUR OWN IBM CLOUD API KEY

# IBM watsonx.ai Project ID (found in watsonx.ai → Project Settings)
WATSONX_PROJECT_ID=USE YOUR OWN PROJECT ID

# IBM watsonx.ai API URL – use the ML endpoint, NOT the web console URL
# Sydney:       https://au-syd.ml.cloud.ibm.com   <-- correct for this project
# US Dallas:    https://us-south.ml.cloud.ibm.com
# EU Frankfurt: https://eu-de.ml.cloud.ibm.com
# Tokyo:        https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Flask secret key – generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=nba-accreditation-ibm-watsonx-2026

# Flask environment (development | production)
FLASK_ENV=development

# Port (default 5000; IBM Code Engine expects 8080)
PORT=5000

# Path to the NBA General Manual PDF inside the knowledge_base folder
NBA_PDF_FILENAME=NBA_PDF_FILENAME.pdf

# Granite model ID to use for generation
# granite-3-8b-instruct  = general-purpose chat/RAG model  <-- use this
# granite-guardian-3-8b  = safety classifier only, NOT for chat
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# Number of top-k chunks to retrieve from vector store
RAG_TOP_K=5

# Maximum new tokens for generation
MAX_NEW_TOKENS=1024
